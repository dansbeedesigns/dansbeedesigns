---
import '../styles/global.css';
import { constellation } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
}

const {
  title,
  description = 'Woodworking at any age — solid builds, honest process, no sponsors.',
  image = '/images/og-default.png',
  type = 'website',
  publishedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
const siteName = 'Dansbee Designs';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: siteName,
      url: Astro.site,
      description: 'Woodworking at any age — solid builds, honest process, no sponsors.',
      sameAs: constellation.map((site) => site.url),
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto+Slab:wght@300;400;500&family=Josefin+Sans:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <div class="accent-bar"></div>

    <header class="border-b border-teal-mid/30 bg-teal-deep/40">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href="/" class="font-display text-xl font-bold uppercase tracking-[0.15em] text-white">
          Dansbee <span class="text-amber">Designs</span>
        </a>
        <ul class="flex gap-8 font-badge text-sm font-semibold uppercase tracking-[0.1em] text-cream">
          <li><a href="/" class="transition-colors hover:text-amber">Home</a></li>
          <li><a href="/about" class="transition-colors hover:text-amber">About</a></li>
          <li><a href="/services" class="transition-colors hover:text-amber">Services</a></li>
          <li><a href="/blog" class="transition-colors hover:text-amber">Blog</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-teal-mid/30 bg-teal-deep/40">
      <div class="mx-auto max-w-6xl px-6 py-10 text-center">
        <p class="font-badge text-xs font-semibold uppercase tracking-[0.2em] text-amber-light">
          No Sponsors &middot; No Affiliate Links &middot; Just Honest Experience
        </p>

        <ul class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-badge text-xs font-semibold uppercase tracking-[0.1em] text-cream/80">
          {constellation.map((site) => (
            <li>
              <a href={site.url} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-amber">
                {site.name}
              </a>
            </li>
          ))}
        </ul>

        <p class="mt-6 font-body text-sm text-cream/70">
          &copy; {new Date().getFullYear()} Dansbee Designs. Peace, love, and sawdust.
        </p>
      </div>
    </footer>
  </body>
</html>
