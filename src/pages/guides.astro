---
import Layout from '../layouts/Layout.astro';
import { guides } from '../data/guides';
---

<Layout
  title="Free Woodworking Guides | Dansbee Designs"
  description="Download free woodworking guides from Dansbee Designs. Enter your email to get instant access — no mailing list spam, just honest woodworking knowledge."
>
  <!-- Hero -->
  <section class="border-b border-teal-mid/30 bg-teal-deep/30">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="font-badge text-xs font-semibold uppercase tracking-[0.25em] text-amber">
        Free Downloads
      </p>
      <h1 class="font-display mt-4 max-w-3xl text-5xl font-bold uppercase leading-[1.05] tracking-tight text-white md:text-6xl">
        Free <span class="text-amber">Guides.</span>
      </h1>
      <p class="mt-6 max-w-xl font-body text-lg font-light leading-relaxed text-cream/90">
        Practical woodworking knowledge distilled into guides you can keep. Enter your email,
        get a download link — no drip campaigns, no upsells.
      </p>
    </div>
  </section>

  <!-- Guides grid -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {guides.map((guide) => (
        <div
          class="guide-card flex flex-col border border-teal-mid/30 bg-teal-darkest/40"
          data-guide-key={guide.key}
          data-guide-title={guide.title}
        >
          {guide.coverImage && (
            <div class="aspect-[4/3] overflow-hidden border-b border-teal-mid/30">
              <img
                src={guide.coverImage}
                alt={guide.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          )}

          <div class="relative flex flex-1 flex-col p-6">
            <div class="accent-bar-vertical absolute left-0 top-6 h-8"></div>

            <h2 class="font-display text-xl font-bold uppercase tracking-wide text-white">
              {guide.title}
            </h2>
            <p class="mt-3 font-body text-base font-light leading-relaxed text-cream/80">
              {guide.description}
            </p>

            <!-- Default state: CTA button -->
            <div class="guide-cta mt-6">
              <button
                class="guide-request-btn w-full bg-amber px-6 py-3 font-badge text-sm font-semibold uppercase tracking-[0.1em] text-teal-darkest transition-colors hover:bg-amber-light"
                type="button"
              >
                Get Free Guide
              </button>
            </div>

            <!-- Email form (hidden until button clicked) -->
            <form class="guide-form mt-6 hidden" novalidate>
              <label class="block font-badge text-xs font-semibold uppercase tracking-[0.15em] text-cream/70">
                Your Email
              </label>
              <input
                type="email"
                name="email"
                required
                placeholder="you@example.com"
                class="guide-email-input mt-2 w-full border border-teal-mid/50 bg-teal-darkest px-4 py-3 font-body text-sm text-cream placeholder-cream/40 outline-none focus:border-amber"
              />
              <p class="guide-error mt-2 hidden font-badge text-xs font-semibold text-red-400"></p>
              <button
                type="submit"
                class="guide-submit-btn mt-3 w-full bg-amber px-6 py-3 font-badge text-sm font-semibold uppercase tracking-[0.1em] text-teal-darkest transition-colors hover:bg-amber-light disabled:cursor-not-allowed disabled:opacity-50"
              >
                Send My Download Link
              </button>
              <button
                type="button"
                class="guide-cancel-btn mt-2 w-full px-6 py-2 font-badge text-xs font-semibold uppercase tracking-[0.1em] text-cream/50 transition-colors hover:text-cream"
              >
                Cancel
              </button>
            </form>

            <!-- Success state (hidden until download is ready) -->
            <div class="guide-success mt-6 hidden">
              <p class="font-badge text-xs font-semibold uppercase tracking-[0.15em] text-amber">
                Your guide is ready
              </p>
              <a
                href="#"
                class="guide-download-link mt-3 flex w-full items-center justify-center gap-2 border border-amber bg-transparent px-6 py-3 font-badge text-sm font-semibold uppercase tracking-[0.1em] text-amber transition-colors hover:bg-amber hover:text-teal-darkest"
                download
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download PDF
              </a>
              <p class="mt-3 font-body text-xs font-light text-cream/50">
                Link expires in 1 hour. Need another? Just re-enter your email above.
              </p>
              <button
                type="button"
                class="guide-reset-btn mt-2 font-badge text-xs font-semibold uppercase tracking-[0.1em] text-cream/40 hover:text-cream/70"
              >
                ← Get another guide
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('.guide-card').forEach((card) => {
    const guideKey = card.dataset.guideKey!;

    const cta = card.querySelector<HTMLElement>('.guide-cta')!;
    const requestBtn = card.querySelector<HTMLButtonElement>('.guide-request-btn')!;
    const form = card.querySelector<HTMLFormElement>('.guide-form')!;
    const emailInput = card.querySelector<HTMLInputElement>('.guide-email-input')!;
    const errorEl = card.querySelector<HTMLElement>('.guide-error')!;
    const submitBtn = card.querySelector<HTMLButtonElement>('.guide-submit-btn')!;
    const cancelBtn = card.querySelector<HTMLButtonElement>('.guide-cancel-btn')!;
    const successEl = card.querySelector<HTMLElement>('.guide-success')!;
    const downloadLink = card.querySelector<HTMLAnchorElement>('.guide-download-link')!;
    const resetBtn = card.querySelector<HTMLButtonElement>('.guide-reset-btn')!;

    function showForm() {
      cta.classList.add('hidden');
      form.classList.remove('hidden');
      successEl.classList.add('hidden');
      emailInput.focus();
    }

    function showSuccess(token: string) {
      form.classList.add('hidden');
      cta.classList.add('hidden');
      successEl.classList.remove('hidden');
      downloadLink.href = `/api/download/${token}`;
    }

    function reset() {
      successEl.classList.add('hidden');
      form.classList.add('hidden');
      cta.classList.remove('hidden');
      emailInput.value = '';
      hideError();
    }

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function hideError() {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }

    requestBtn.addEventListener('click', showForm);
    cancelBtn.addEventListener('click', reset);
    resetBtn.addEventListener('click', reset);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      const email = emailInput.value.trim();
      if (!email) {
        showError('Please enter your email address.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Getting your link…';

      try {
        const res = await fetch('/api/request-guide', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, guideKey }),
        });

        const data = await res.json() as { token?: string; error?: string };

        if (!res.ok || !data.token) {
          showError(data.error ?? 'Something went wrong. Please try again.');
          return;
        }

        showSuccess(data.token);
      } catch {
        showError('Network error. Please check your connection and try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send My Download Link';
      }
    });
  });
</script>
